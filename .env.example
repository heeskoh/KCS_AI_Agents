# === LLM ===
# 사용할 LLM 공급자: openai | anthropic  (기본값: openai)
LLM_PROVIDER=openai

# 모델명 (비워두면 공급자 기본값 사용)
#   openai    기본값: gpt-4o
#   anthropic 기본값: claude-opus-4-7
LLM_MODEL=

# 생성 온도 (0.0 ~ 1.0, 기본값: 0)
LLM_TEMPERATURE=0

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === Web search (선택, agent_web 에서 사용) ===
TAVILY_API_KEY=
SERPAPI_API_KEY=

# === 법제처 국가법령정보 Open API (선택, agent_law 에서 사용) ===
# 발급: https://open.law.go.kr → 회원가입 → API 이용신청 → OC(이메일 또는 발급키) 확인
# 없으면 LLM 직접 법령 지식으로 대체
LAW_API_KEY=

# === 특허청 KIPRIS Open API (선택, agent_patent 에서 사용) ===
# 발급: https://plus.kipris.or.kr → 회원가입 → API 신청 → ServiceKey 발급
# 없으면 LLM 특허 문맥 분석으로 대체
KIPRIS_API_KEY=

# === Web server ===
HOST=127.0.0.1
PORT=8000
