{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "kcs-portal",
      "runtimeExecutable": "venv\\Scripts\\python.exe",
      "runtimeArgs": ["web_server.py"],
      "env": { "PYTHONUTF8": "1", "PYTHONIOENCODING": "utf-8" },
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "demo-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8001", "--directory", "dist"],
      "port": 8001,
      "autoPort": false
    },
    {
      "name": "kcs-portal-verify",
      "runtimeExecutable": "venv\\Scripts\\python.exe",
      "runtimeArgs": ["web_server.py"],
      "env": { "PORT": "8001", "PYTHONUTF8": "1", "PYTHONIOENCODING": "utf-8" },
      "port": 8001,
      "autoPort": false
    },
    {
      "name": "crime-sim",
      "runtimeExecutable": "venv\\Scripts\\python.exe",
      "runtimeArgs": ["-m", "http.server", "8017", "--directory", "docs/crime-case-sim"],
      "port": 8017,
      "autoPort": false
    }
  ]
}
