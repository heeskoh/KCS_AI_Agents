:root {
  color-scheme: light;
  font-family: "Segoe UI", "Noto Sans KR", Arial, sans-serif;
  --bg: #f4f6f8;
  --surface: #ffffff;
  --surface-soft: #f8fafc;
  --sidebar: #111827;
  --sidebar-soft: #1f2937;
  --line: #d9e0e7;
  --line-strong: #b7c2ce;
  --ink: #16202a;
  --muted: #6b7785;
  --blue: #2563eb;
  --blue-soft: #e8f0ff;
  --cyan: #0f9db8;
  --green: #15803d;
  --amber: #b45309;
  --red: #c2410c;
  --violet: #6d5bd0;
  --shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  height: 100vh;
  display: grid;
  grid-template-columns: 340px minmax(0, 1fr);
  background: var(--bg);
  color: var(--ink);
  overflow: hidden;
}

button,
select,
textarea,
input {
  font: inherit;
}

button {
  border: 0;
}

.sidebar {
  height: 100vh;
  padding: 22px 18px;
  background: var(--sidebar);
  color: #f8fafc;
  overflow: auto;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 22px;
}

.brand-mark {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 8px;
  background: #ffffff;
  color: var(--blue);
  font-weight: 900;
}

.brand h1 {
  margin: 0;
  font-size: 21px;
  line-height: 1.1;
  letter-spacing: 0;
}

.brand p {
  margin: 5px 0 0;
  color: #9ca3af;
  font-size: 13px;
}

.field {
  display: grid;
  gap: 9px;
  margin-bottom: 16px;
  color: #dbe4ee;
  font-size: 14px;
  font-weight: 800;
}

.field select,
.mini-field select,
textarea {
  width: 100%;
  min-width: 0;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: #fff;
  color: var(--ink);
}

.field select,
.mini-field select {
  height: 42px;
  padding: 0 38px 0 12px;
}

.source-card {
  margin: 12px 0;
  padding: 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 8px;
  background: var(--sidebar-soft);
}

.source-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
  color: #e5e7eb;
  font-size: 14px;
  font-weight: 900;
}

.source-card-head strong {
  padding: 3px 7px;
  border-radius: 999px;
  background: rgba(96, 165, 250, 0.18);
  color: #bfdbfe;
  font-size: 11px;
}

.permission-row {
  min-height: 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  color: #cbd5e1;
  font-size: 13px;
  font-weight: 700;
}

.permission-row input {
  appearance: none;
  width: 42px;
  height: 24px;
  flex: 0 0 auto;
  border-radius: 999px;
  background: #64748b;
  position: relative;
  cursor: pointer;
}

.permission-row input::after {
  content: "";
  position: absolute;
  top: 4px;
  left: 4px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.18s ease;
}

.permission-row input:checked {
  background: var(--blue);
}

.permission-row input:checked::after {
  transform: translateX(18px);
}

.run-button {
  width: 100%;
  height: 46px;
  margin-top: 18px;
  border-radius: 8px;
  background: var(--blue);
  color: #fff;
  font-weight: 900;
  cursor: pointer;
  box-shadow: 0 14px 30px rgba(37, 99, 235, 0.28);
}

.run-button:disabled {
  opacity: 0.65;
  cursor: progress;
}

.shutdown-button {
  width: 100%;
  height: 40px;
  margin-top: 10px;
  border: 1px solid rgba(248, 113, 113, 0.35);
  border-radius: 8px;
  background: rgba(127, 29, 29, 0.28);
  color: #fecaca;
  font-weight: 900;
  cursor: pointer;
}

.shutdown-button:hover {
  background: rgba(153, 27, 27, 0.42);
}

.shutdown-button:disabled {
  opacity: 0.72;
  cursor: progress;
}

.app {
  min-width: 0;
  height: 100vh;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
  overflow: hidden;
}

.app-header {
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1px solid var(--line);
  background: rgba(244, 246, 248, 0.92);
  backdrop-filter: blur(12px);
}

.top-tabs {
  height: 64px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 22px;
}

.top-tab {
  min-width: 132px;
  height: 38px;
  padding: 0 16px;
  border-radius: 8px;
  background: transparent;
  color: var(--muted);
  font-weight: 900;
  cursor: pointer;
}

.top-tab.active {
  background: var(--surface);
  color: var(--blue);
  box-shadow: var(--shadow);
}

.screen {
  display: none;
  height: calc(100vh - 64px);
  min-height: 0;
  padding: 22px;
  overflow: auto;
}

.screen.active {
  display: block;
}

.screen[data-screen-panel="analysis"].active {
  height: calc(100vh - 64px);
  min-height: 0;
  overflow: hidden;
}

.screen[data-screen-panel="report"].active {
  height: calc(100vh - 64px);
  min-height: 0;
  overflow: hidden;
}

.analysis-shell {
  height: 100%;
  min-height: 0;
  display: grid;
  grid-template-columns: 310px minmax(0, 1fr);
  grid-template-rows: 286px minmax(360px, 1fr);
  gap: 16px;
}

.scenario-editor,
.scenario-flow-panel,
.runtime-panel,
.profile-hero,
.profile-panel,
.report-panel {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  box-shadow: var(--shadow);
}

.scenario-editor {
  position: relative;
  grid-column: 1;
  grid-row: 1;
  min-height: 286px;
  padding: 16px;
  display: flex;
  flex-direction: column;
}

.editor-box h2,
.scenario-flow-panel h2,
.runtime-header h3,
.report-panel h2 {
  margin: 0;
  font-size: 18px;
  letter-spacing: 0;
}

.mini-field {
  display: grid;
  gap: 8px;
  margin-top: 14px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 900;
}

.mini-field.source-select {
  margin-top: 14px;
}

textarea {
  min-height: 118px;
  padding: 12px;
  resize: vertical;
  line-height: 1.55;
}

.text-action {
  align-self: flex-end;
  margin-top: auto;
  padding: 8px 0 0;
  background: transparent;
  color: var(--muted);
  font-size: 13px;
  font-weight: 900;
  cursor: pointer;
}

.text-action.delete {
  color: #be123c;
}

.text-action:disabled {
  opacity: 0.45;
  cursor: default;
}

.analysis-workspace {
  min-width: 0;
  grid-column: 2;
  grid-row: 1;
}

.scenario-flow-panel {
  min-height: 286px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scenario-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  padding: 18px 20px 0;
}

.scenario-flow-panel p {
  margin: 7px 0 0;
  color: var(--muted);
  font-size: 13px;
  font-weight: 700;
}

.primary-small {
  height: 34px;
  padding: 0 14px;
  border-radius: 8px;
  background: var(--blue);
  color: #fff;
  font-size: 13px;
  font-weight: 900;
  white-space: nowrap;
  cursor: pointer;
  box-shadow: 0 10px 22px rgba(37, 99, 235, 0.18);
}

.scenario-flow {
  min-height: 0;
  flex: 1;
  margin: 0;
  padding: 20px 20px 22px;
  display: flex;
  align-items: flex-start;
  gap: 14px;
  overflow-x: auto;
  list-style: none;
}

.scenario-row {
  position: relative;
  flex: 0 0 172px;
  min-height: 134px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface-soft);
  cursor: grab;
}

.scenario-row.selected {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.14);
}

.scenario-row.dragging {
  opacity: 0.48;
}

.scenario-row.drag-over {
  box-shadow: 0 0 0 3px rgba(15, 157, 184, 0.22);
}

.scenario-row.db {
  border-top: 4px solid var(--blue);
}

.scenario-row.rag_customs,
.scenario-row.rag_trade,
.scenario-row.rag_audit,
.scenario-row.rag_investigation,
.scenario-row.rag_global {
  border-top: 4px solid var(--green);
}

.scenario-row.bigdata {
  border-top: 4px solid var(--cyan);
}

.scenario-row.web {
  border-top: 4px solid var(--amber);
}

.scenario-row.report,
.scenario-row.validation {
  border-top: 4px solid var(--violet);
}

.scenario-item {
  height: 100%;
  padding: 14px;
  display: grid;
  grid-template-rows: auto auto 1fr;
  gap: 10px;
}

.scenario-order {
  width: 26px;
  height: 26px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: #eef2ff;
  color: var(--blue);
  font-size: 12px;
  font-weight: 900;
}

.scenario-pill {
  display: block;
  font-size: 16px;
  font-weight: 900;
  line-height: 1.25;
  word-break: keep-all;
}

.scenario-item p {
  margin: 0;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.45;
}

.runtime-panel {
  grid-column: 1 / -1;
  grid-row: 2;
  min-height: 0;
  height: 100%;
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
  overflow: hidden;
}

.runtime-header {
  min-height: 54px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px;
  border-bottom: 1px solid var(--line);
}

.runtime-header span {
  color: var(--blue);
  font-weight: 900;
}

.progress-line {
  display: grid;
  grid-template-columns: 58px 1fr;
  gap: 12px;
  align-items: center;
  padding: 14px 18px;
  color: var(--muted);
  font-weight: 900;
}

.progress-line div {
  height: 8px;
  border-radius: 999px;
  background: #e5e7eb;
  overflow: hidden;
}

.progress-line i {
  display: block;
  width: 0;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}

#analysisOutput {
  display: none;
}

.step-accordion {
  min-height: 0;
  overflow: auto;
  overscroll-behavior: contain;
}

.empty-state {
  padding: 24px;
  color: var(--muted);
  font-weight: 800;
}

.step-panel {
  border-top: 1px solid var(--line);
}

.step-toggle {
  width: 100%;
  min-height: 54px;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 0 18px;
  background: var(--surface);
  color: var(--ink);
  font-weight: 900;
  text-align: left;
  cursor: pointer;
}

.step-toggle span {
  min-width: 0;
}

.step-toggle i {
  margin-left: auto;
  font-style: normal;
  font-size: 22px;
  transition: transform 0.15s ease;
}

.step-panel.open .step-toggle i {
  transform: rotate(90deg);
}

.step-status {
  padding: 3px 8px;
  border-radius: 999px;
  background: #eef2ff;
  color: var(--blue);
  font-size: 12px;
  font-style: normal;
}

.step-body {
  display: none;
  max-height: 420px;
  margin: 0;
  padding: 18px;
  overflow: auto;
  overscroll-behavior: contain;
  border-top: 1px solid var(--line);
  background: #0f172a;
  color: #e5edf6;
  font-family: "Consolas", "Noto Sans KR", monospace;
  font-size: 14px;
  line-height: 1.6;
  overflow-wrap: anywhere;
}

.step-body.markdown-output,
.step-body .markdown-output,
.step-body p,
.step-body li,
.step-body h1,
.step-body h2,
.step-body h3,
.step-body h4,
.step-body strong,
.step-body em {
  color: #f8fafc;
}

.step-body h1,
.step-body h2,
.step-body h3,
.step-body h4 {
  color: #ffffff;
}

.step-body code {
  color: #e0f2fe;
  background: rgba(59, 130, 246, 0.2);
}

.step-body ul,
.step-body ol {
  color: #f8fafc;
}

.step-panel.open .step-body {
  display: block;
}

pre {
  margin: 0;
  white-space: pre-wrap;
  word-break: keep-all;
  overflow-wrap: anywhere;
  font-family: "Noto Sans KR", "Segoe UI", Arial, sans-serif;
  line-height: 1.55;
}

.profile-dashboard {
  display: grid;
  gap: 16px;
}

.profile-hero,
.profile-panel {
  padding: 22px;
}

.profile-title-row {
  display: flex;
  align-items: center;
  gap: 16px;
}

.profile-logo {
  width: 58px;
  height: 58px;
  display: grid;
  place-items: center;
  border-radius: 8px;
  background: var(--blue-soft);
  color: var(--blue);
  font-weight: 900;
}

.profile-name-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px;
}

.profile-name-line h2 {
  margin: 0;
  font-size: 24px;
}

.profile-title-row p {
  margin: 8px 0 0;
  color: var(--muted);
  font-weight: 700;
}

.badge {
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 900;
}

.badge.danger {
  background: #fff1f2;
  color: #be123c;
}

.badge.warn {
  background: #fffbeb;
  color: var(--amber);
}

.badge.safe,
.badge.neutral {
  background: #ecfdf5;
  color: var(--green);
}

.profile-kpis {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12px;
  margin-top: 22px;
}

.profile-kpis div {
  min-height: 108px;
  padding: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface-soft);
}

.profile-kpis span {
  color: var(--muted);
  font-size: 13px;
  font-weight: 900;
}

.profile-kpis strong {
  display: block;
  margin-top: 12px;
  font-size: 24px;
}

.profile-kpis em {
  display: block;
  margin-top: 8px;
  color: #8a97a6;
  font-size: 12px;
  font-style: normal;
  font-weight: 700;
}

.profile-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16px;
}

.profile-panel h3 {
  margin: 0 0 16px;
  color: #334155;
  font-size: 17px;
}

.info-rows {
  display: grid;
}

.info-rows div {
  min-height: 40px;
  display: grid;
  grid-template-columns: 150px 1fr;
  align-items: center;
  gap: 14px;
  border-bottom: 1px solid #eef2f6;
}

.info-rows span {
  color: var(--muted);
  font-weight: 800;
}

.info-rows strong {
  text-align: right;
  font-weight: 900;
}

.risk-panel-head {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 16px;
}

.risk-circle {
  width: 74px;
  height: 74px;
  display: grid;
  place-items: center;
  align-content: center;
  border: 4px solid #fca5a5;
  border-radius: 50%;
  color: #be123c;
}

.risk-circle strong {
  display: block;
  font-size: 24px;
  line-height: 1;
}

.risk-circle span {
  font-size: 12px;
  font-weight: 900;
}

.risk-bars {
  display: grid;
  gap: 14px;
}

.risk-bar-row div {
  display: flex;
  justify-content: space-between;
  margin-bottom: 7px;
  color: var(--muted);
  font-weight: 800;
}

.risk-bar-row strong {
  color: #be123c;
}

.risk-bar-row i {
  display: block;
  height: 9px;
  border-radius: 999px;
  background: #e5e7eb;
  overflow: hidden;
}

.risk-bar-row b {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f59e0b, #ef4444);
}

.declaration-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
}

.declaration-table th,
.declaration-table td {
  padding: 12px 10px;
  border-bottom: 1px solid #eef2f6;
  text-align: left;
  word-break: keep-all;
}

.declaration-table th {
  color: var(--muted);
  font-size: 13px;
}

.declaration-table td {
  font-weight: 800;
}

.status-pill {
  display: inline-flex;
  min-width: 58px;
  justify-content: center;
  padding: 4px 8px;
  border-radius: 999px;
  background: #eef2ff;
  color: var(--blue);
  font-size: 12px;
  font-weight: 900;
}

.status-pill.review {
  background: #fffbeb;
  color: var(--amber);
}

.status-pill.normal {
  background: #ecfdf5;
  color: var(--green);
}

.status-pill.inspect,
.status-pill.hold {
  background: #fff1f2;
  color: #be123c;
}

.profile-timeline {
  display: grid;
  margin: 0;
  padding: 0;
  list-style: none;
}

.profile-timeline li {
  min-height: 40px;
  display: grid;
  grid-template-columns: 100px 24px 1fr;
  align-items: center;
  border-bottom: 1px solid #eef2f6;
}

.profile-timeline time {
  color: var(--muted);
  font-weight: 800;
}

.profile-timeline span {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--blue);
}

.profile-timeline p {
  margin: 0;
  font-weight: 800;
}

.report-layout {
  height: 100%;
  min-height: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 420px;
  gap: 16px;
}

.report-panel {
  padding: 22px;
  min-height: 0;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
  overflow: hidden;
}

.report-panel > .markdown-output {
  min-height: 0;
  margin-top: 16px;
  padding: 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface-soft);
  overflow: auto;
  overscroll-behavior: contain;
}

.markdown-output {
  color: inherit;
  line-height: 1.65;
  word-break: keep-all;
  overflow-wrap: anywhere;
}

.markdown-output h1,
.markdown-output h2,
.markdown-output h3,
.markdown-output h4 {
  margin: 18px 0 10px;
  color: inherit;
  line-height: 1.35;
  letter-spacing: 0;
}

.markdown-output h1:first-child,
.markdown-output h2:first-child,
.markdown-output h3:first-child,
.markdown-output h4:first-child {
  margin-top: 0;
}

.markdown-output h1 {
  font-size: 22px;
}

.markdown-output h2 {
  font-size: 19px;
}

.markdown-output h3 {
  font-size: 17px;
}

.markdown-output h4 {
  font-size: 15px;
}

.markdown-output p {
  margin: 8px 0;
}

.markdown-output ul,
.markdown-output ol {
  margin: 8px 0 12px;
  padding-left: 22px;
}

.markdown-output li {
  margin: 5px 0;
}

.markdown-output strong {
  font-weight: 900;
}

.markdown-output code {
  padding: 2px 5px;
  border-radius: 5px;
  background: rgba(148, 163, 184, 0.18);
  font-family: "Consolas", "Noto Sans KR", monospace;
  font-size: 0.94em;
}

.permission-popup {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: grid;
  place-items: center;
  background: rgba(15, 23, 42, 0.38);
}

.permission-popup[hidden] {
  display: none;
}

.popup-card {
  width: min(420px, calc(100vw - 40px));
  padding: 22px;
  border-radius: 8px;
  background: #fff;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
}

.popup-card h2 {
  margin: 0 0 12px;
  font-size: 20px;
}

.popup-card p {
  margin: 0 0 18px;
  line-height: 1.55;
}

.popup-card button {
  width: 100%;
  height: 38px;
  border-radius: 8px;
  background: var(--blue);
  color: #fff;
  font-weight: 900;
  cursor: pointer;
}

@media (max-width: 1180px) {
  body,
  .analysis-shell,
  .profile-grid,
  .report-layout {
    grid-template-columns: 1fr;
  }

  body {
    height: auto;
    min-height: 100vh;
    overflow: auto;
  }

  .sidebar {
    height: auto;
    max-height: none;
  }

  .app {
    height: auto;
    overflow: visible;
  }

  .screen[data-screen-panel="analysis"].active {
    height: auto;
    overflow: visible;
  }

  .analysis-shell {
    height: auto;
  }

  .analysis-workspace,
  .scenario-editor,
  .runtime-panel {
    grid-column: auto;
    grid-row: auto;
  }

  .profile-kpis {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .screen {
    padding: 14px;
  }

  .top-tabs {
    overflow-x: auto;
    padding: 0 14px;
  }

  .profile-kpis {
    grid-template-columns: 1fr;
  }

  .profile-title-row {
    align-items: flex-start;
  }

  .declaration-table {
    min-width: 720px;
  }

  .profile-panel {
    overflow-x: auto;
  }
}
